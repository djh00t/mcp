# ChromaDB MCP HTTP/SSE Server Configuration

# Server Configuration
HTTP_PORT=8002
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# Docker Configuration
MCP_IMAGE=mcp/chroma:latest
DOCKER_NETWORK=chromadb-mcp_default

# Development Configuration
NODE_ENV=development
DEBUG=false

# Optional: Override default settings for production
# HTTP_PORT=80
# CHROMADB_HOST=production-chromadb.example.com
# CHROMADB_PORT=443
